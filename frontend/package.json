{
  "name": "Matcha_center",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "npm run prebuild:vercel && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "prebuild:vercel": "node scripts/set-env.js",
    "build:vercel": "npm run prebuild:vercel && ng build --configuration production --output-path=dist/frontend"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@coreui/angular": "^5.6.13",
    "@coreui/coreui": "^5.5.0",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-angular": "^5.6.13",
    "@coreui/utils": "^2.0.2",
    "@stripe/stripe-js": "^8.9.0",
    "chart.js": "^4.5.1",
    "ng2-charts": "^8.0.0",
    "ngx-scrollbar": "^19.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
